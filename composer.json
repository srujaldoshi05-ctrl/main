{
  "name": "yourname/php-project",
  "description": "Simple PHP project with Composer",
  "type": "project",
  "license": "MIT",

  "require": {
    "php": ">=8.0"
  },

  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },

  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },

  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },

  "scripts": {
    "test": "vendor/bin/phpunit"
  },

  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
